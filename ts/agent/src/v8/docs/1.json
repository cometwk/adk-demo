            },
            "validUntil": {
              "description": "ISO 8601: 该值失效的时间",
              "type": "string"
            }
          },
          "required": ["entityId", "property", "value"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "lookup_fact",
        "description": "查询实体属性的已绑定事实值。在将值传递给 call_method 之前调用此方法，以避免盲零错误。如果事实尚未绑定，返回 null。",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "entityId": {
              "type": "string",
              "description": "实体 ID"
            },
            "property": {
              "type": "string",
              "description": "属性名称"
            }
          },
          "required": ["entityId", "property"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "aggregate_facts",
        "description": "对多个实体的属性绑定事实进行聚合计算。支持操作：sum, avg, count, min, max。聚合后使用 bind_fact 绑定结果。",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "entityIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "要聚合的实体 ID"
            },
            "property": {
              "type": "string",
              "description": "要聚合的属性"
            },
            "operation": {
              "type": "string",
              "enum": ["sum", "avg", "count", "min", "max"],
              "description": "聚合操作"
            }
          },
          "required": ["entityIds", "property", "operation"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "propose_candidates",
        "description": "为决策提出互斥的候选答案。必须在记录证据之前调用一次（或更新）。示例: [{label:'HIGH',description:'...'}, {label:'MEDIUM',...}, {label:'LOW',...}]",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "candidates": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "简短的答案标签（如 HIGH, MEDIUM, LOW）"
                  },
                  "description": {
                    "type": "string",
                    "description": "对该候选的一句话解释"
                  }
                },
                "required": ["label", "description"],
                "additionalProperties": false
              }
            }
          },
          "required": ["candidates"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "record_evidence",
        "description": "记录一条证据并将其关联到一个或多个候选答案。基础置信度由来源类型决定；你可以应用 {-0.2, 0, +0.2} 范围内的修正值。请引用与该证据相关的规则 ID。",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "sourceKind": {
              "type": "string",
              "enum": ["property", "method_result", "rule_evaluation", "aggregation", "event", "causal_path"],
              "description": "证据来源类型"
            },
            "entityIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "该证据涉及的实体 ID"
            },
            "relatedRuleIds": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "该证据相关的规则 ID"
            },
            "content": {
              "type": "string",
              "description": "证据的人类可读描述"
            },
            "baseConfidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "基础置信度 0..1"
            },
            "confidenceModifier": {
              "default": 0,
              "description": "LLM 修正值 ∈ {-0.2, 0, +0.2}",
              "type": "number",
              "minimum": -0.2,
              "maximum": 0.2
            },
            "supportsCandidateIds": {
              "default": [],
              "description": "该证据支持的候选 ID",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["sourceKind", "entityIds", "relatedRuleIds", "content", "baseConfidence"],
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "list_workspace",
        "description": "列出当前工作区状态：候选、证据和不确定性。",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "declare_uncertainty",
        "description": "记录已知的不确定性 —— 缺失的事实或模糊的信号会影响置信度。系统会在最终响应中展示未解决的不确定性。",
        "parameters": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "不确定的内容"
            },
            "impact": {
              "type": "string",
              "enum": ["low", "medium", "high"],
              "description": "该不确定性对决策的影响程度"
            },
            "missingFacts": {
              "default": [],
              "description": "缺失的属性名称",
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nextQuery": {
              "description": "建议的后续查询以解决此不确定性",
              "type": "string"
            }
          },
          "required": ["description", "impact"],
          "additionalProperties": false
        }
      }
    }
  ],
  "tool_choice": "auto",
  "stream": true
}
