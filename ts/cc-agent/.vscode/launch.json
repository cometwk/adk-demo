{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [
        "Next.js Server",
        "Chrome"
      ]
    }
  ],
  "configurations": [
    {
      "name": "Next.js Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ]
}